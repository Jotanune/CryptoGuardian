# CryptoGuardian — Environment Variables
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Mode ──────────────────────────────────────────────
MODE=paper                          # paper | live
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING

# ── Hyperliquid DEX ──────────────────────────────────
HYPERLIQUID_PRIVATE_KEY=0x...       # EIP-712 signing key
HYPERLIQUID_TESTNET=false

# ── Kraken CEX (EUR bridge only) ─────────────────────
KRAKEN_API_KEY=your_key_here
KRAKEN_API_SECRET=your_secret_here

# ── Arbitrum L2 (balance verification) ───────────────
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_RPC_FALLBACK_URL=https://arbitrum.llamarpc.com

# ── Telegram Alerts ──────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF
TELEGRAM_CHAT_ID=your_chat_id

# ── Risk Parameters ──────────────────────────────────
# Exact values are proprietary. Examples shown.
MAX_RISK_PER_TRADE_PCT=1.0
MAX_DAILY_LOSS_PCT=3.0
MAX_DAILY_LOSS_HARD_PCT=5.0
MAX_TOTAL_DRAWDOWN_PCT=10.0
MAX_OPEN_POSITIONS_TOTAL=5
MAX_CONSECUTIVE_LOSSES=3

# ── Database ─────────────────────────────────────────
DB_URL=sqlite:///data/cryptoguardian.db

# ── Profit Extraction ────────────────────────────────
EXTRACTION_DAY=1                    # Day of month
EXTRACTION_PCT=30                   # % of profits to extract
BRIDGE_MODE=kraken                  # kraken | manual
